    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.text || $input.first().json.response || '';\n\nlet analysis;\ntry {\n  const jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    analysis = JSON.parse(jsonMatch[0]);\n  } else {\n    throw new Error('No JSON found');\n  }\n} catch (e) {\n  analysis = {\n    hay_enojados: false,\n    total_correos: 0,\n    correos_enojados: [],\n    resumen: 'No se pudo parsear la respuesta del agente. Revisar manualmente.'\n  };\n}\n\nif (!Array.isArray(analysis.correos_enojados)) {\n  analysis.correos_enojados = [];\n}\nif (typeof analysis.hay_enojados !== 'boolean') {\n  analysis.hay_enojados = analysis.correos_enojados.length > 0;\n}\n\nreturn [{ json: analysis }];"
      },
