    {
      "parameters": {
        "jsCode": "const emails = $input.all();\n\n// Lee un header sin importar el formato de salida del nodo Gmail:\n// crudo (payload.headers[]), objeto parseado, string, o headers{}\nfunction getHeader(json, name) {\n  const lower = name.toLowerCase();\n\n  // 1) Gmail crudo (Simplify = OFF): payload.headers = [{ name, value }]\n  if (Array.isArray(json.payload?.headers)) {\n    const h = json.payload.headers.find(x => (x.name || '').toLowerCase() === lower);\n    if (h?.value) return h.value;\n  }\n\n  // 2) headers como objeto: { from: \"...\", subject: \"...\" }\n  if (json.headers && typeof json.headers === 'object') {\n    const val = json.headers[lower] ?? json.headers[name];\n    if (val) return typeof val === 'string' ? val : (val.text || val.value || '');\n  }\n\n  // 3) campo directo: string u objeto parseado { text, value: [{ address, name }] }\n  const direct = json[lower] ?? json[name.charAt(0).toUpperCase() + name.slice(1)];\n  if (direct) {\n    if (typeof direct === 'string') return direct;\n    return direct.text || direct.value?.[0]?.address || '';\n  }\n\n  return '';\n}\n\nconst formatted = emails.map((e, i) => {\n  const j = e.json;\n  const from = getHeader(j, 'from') || 'Desconocido';\n  const subject = getHeader(j, 'subject') || 'Sin asunto';\n  const body = j.text || j.snippet || j.textHtml?.replace(/<[^>]*>/g, '') || '';\n  const bodyTruncated = body.substring(0, 800);\n  return `[CORREO ${i + 1}]\\nDe: ${from}\\nAsunto: ${subject}\\nMensaje: ${bodyTruncated}\\n${'─'.repeat(40)}`;\n}).join('\\n\\n');\n\nreturn [{\n  json: {\n    emails_text: formatted,\n    total: emails.length,\n    emails_meta: emails.map(e => ({\n      from: getHeader(e.json, 'from') || 'Desconocido',\n      subject: getHeader(e.json, 'subject') || 'Sin asunto',\n      id: e.json.id\n    }))\n  }\n}];"
      },
      "id": "2ed64f10-a262-467f-a460-8f0b32f06c16",
      "name": "Preparar emails para Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1024,
        96
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Eres un asistente especializado en análisis de sentimientos de correos de clientes.\n\nAnaliza los siguientes correos y detecta si alguno proviene de un cliente enojado, frustrado o insatisfecho.\n\nCORREOS A ANALIZAR:\n{{ $json.emails_text }}\n\nINSTRUCCIONES:\n- Lee cada correo cuidadosamente\n- Identifica señales de enojo: lenguaje agresivo, quejas, amenazas, urgencia extrema, insultos, mayúsculas excesivas, signos de exclamación múltiples, expresiones de decepción severa\n- Ignora correos de marketing, newsletters o spam que hayan pasado el filtro\n\nResponde ÚNICAMENTE con un objeto JSON válido, sin texto adicional antes ni después:\n{\n  \"hay_enojados\": true,\n  \"total_correos\": 3,\n  \"correos_enojados\": [\n    {\n      \"remitente\": \"cliente@ejemplo.com\",\n      \"asunto\": \"Asunto del correo\",\n      \"nivel_enojo\": \"alto\",\n      \"razon\": \"Breve descripción de por qué está enojado\"\n    }\n  ],\n  \"resumen\": \"Resumen general del estado de los clientes en esta revisión\"\n}"
      },
