# Database — Supabase Postgres. Use the *direct* connection string (port 5432),
# not the PgBouncer transaction-mode pooler on port 6543: this backend is a
# single always-on process with its own SQLAlchemy connection pool, so it
# doesn't need PgBouncer, and transaction-mode pooling breaks features some
# drivers rely on (server-side prepared statements). Find it in Supabase under
# Project Settings -> Database -> Connection string -> URI, then swap the
# scheme to postgresql+psycopg and keep sslmode=require.
DATABASE_URL=postgresql+psycopg://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# Encryption key for IMAP app passwords at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# JWT session signing secret. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# SMTP (used both for magic-link emails and mood reports).
# Works with a real mailbox or any transactional provider's SMTP endpoint
# (Resend / SendGrid / Amazon SES) — just point these at whichever you use.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=reports@example.com
SMTP_USE_TLS=true

# CORS / cookies — the exact origin the frontend is served from (no wildcard).
FRONTEND_ORIGIN=http://localhost:5173

# Worker timing
POLL_INTERVAL_MINUTES=3
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=30
DIGEST_DAILY_HOUR=8
DIGEST_WEEKLY_DAY=mon
DIGEST_WEEKLY_HOUR=8

# Set to false only for local http development (disables Secure cookie flag)
COOKIE_SECURE=true
