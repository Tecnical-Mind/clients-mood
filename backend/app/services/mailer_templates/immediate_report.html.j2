{% extends "base.html.j2" %}
{% block content %}
<div style="border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px;">
  <p style="margin: 0 0 8px 0; font-size: 13px; color: #6b7280;">De: <strong style="color:#1f2933;">{{ analysis.sender }}</strong></p>
  <p style="margin: 0 0 12px 0; font-size: 14px;">Asunto: {{ analysis.subject }}</p>
  <p style="margin: 0 0 12px 0;">
    <span style="display:inline-block; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; background: {{ badge_bg }}; color: {{ badge_fg }};">
      {{ analysis.mood_label|upper }}
    </span>
    {% if analysis.requires_attention %}
    <span style="display:inline-block; margin-left: 6px; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; background: #fee2e2; color: #991b1b;">
      REQUIERE ATENCIÓN
    </span>
    {% endif %}
  </p>
  <p style="font-size: 14px; line-height: 1.5; margin: 0 0 8px 0;">{{ analysis.mood_summary }}</p>
  <p style="font-size: 12px; color: #9ca3af; margin: 0;">Puntaje de ánimo: {{ "%.2f"|format(analysis.mood_score) }} · {{ analysis.analyzed_at.strftime("%d/%m/%Y %H:%M") }}</p>
</div>
{% endblock %}
