{% extends "base.html.j2" %}
{% block content %}
<p style="font-size: 13px; color: #6b7280;">Período: {{ period_start.strftime("%d/%m/%Y") }} – {{ period_end.strftime("%d/%m/%Y") }}</p>

<table style="width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 13px;">
  <tr>
    {% for label, count in counts.items() %}
    <td style="padding: 8px 12px; border: 1px solid #e5e7eb; text-align: center;">
      <div style="font-size: 20px; font-weight: 700;">{{ count }}</div>
      <div style="color: #6b7280; text-transform: uppercase; font-size: 11px;">{{ label }}</div>
    </td>
    {% endfor %}
  </tr>
</table>

{% if urgent %}
<h2 style="font-size: 14px; color: #991b1b; margin: 20px 0 8px 0;">Requieren atención ({{ urgent|length }})</h2>
{% for a in urgent %}
<div style="border-left: 3px solid #ef4444; padding: 8px 12px; margin-bottom: 8px; background: #fef2f2;">
  <div style="font-size: 13px; font-weight: 600;">{{ a.sender }}</div>
  <div style="font-size: 13px; margin: 2px 0;">{{ a.subject }}</div>
  <div style="font-size: 12px; color: #6b7280;">{{ a.mood_summary }}</div>
</div>
{% endfor %}
{% endif %}

<h2 style="font-size: 14px; margin: 20px 0 8px 0;">Todos los correos analizados ({{ analyses|length }})</h2>
<table style="width: 100%; border-collapse: collapse; font-size: 12px;">
  <thead>
    <tr style="background: #f9fafb; text-align: left;">
      <th style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb;">Remitente</th>
      <th style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb;">Asunto</th>
      <th style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb;">Ánimo</th>
      <th style="padding: 6px 8px; border-bottom: 1px solid #e5e7eb;">Fecha</th>
    </tr>
  </thead>
  <tbody>
    {% for a in analyses %}
    <tr>
      <td style="padding: 6px 8px; border-bottom: 1px solid #f3f4f6;">{{ a.sender }}</td>
      <td style="padding: 6px 8px; border-bottom: 1px solid #f3f4f6;">{{ a.subject }}</td>
      <td style="padding: 6px 8px; border-bottom: 1px solid #f3f4f6;">{{ a.mood_label }}</td>
      <td style="padding: 6px 8px; border-bottom: 1px solid #f3f4f6;">{{ a.analyzed_at.strftime("%d/%m %H:%M") }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endblock %}
